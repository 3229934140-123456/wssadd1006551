generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Clinic {
  id            String    @id @default(uuid())
  name          String
  code          String    @unique
  address       String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users         User[]
  reports       Report[]
  samplingRules SamplingRule[]
}

model User {
  id                        String    @id @default(uuid())
  username                  String    @unique
  passwordHash              String
  name                      String
  role                      String
  clinicId                  String?
  email                     String?
  phone                     String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  clinic                    Clinic?   @relation(fields: [clinicId], references: [id])
  submittedReports          Report[]  @relation("SubmittedReports")
  assignedTasks             AuditTask[] @relation("AssignedTasks")
  auditFeedbacks            AuditFeedback[] @relation("AuditFeedbackAuditor")
  managedAudits             AuditTask[] @relation("ManagedAudits")
  samplingRulesAsAuditor    SamplingRule[] @relation("SamplingRuleAuditor")
  samplingRulesAsSubmitter  SamplingRule[] @relation("SamplingRuleSubmitter")
  samplingRulesAsCreator    SamplingRule[] @relation("SamplingRuleCreator")
  ruleConfigsAsCreator      RuleConfig[] @relation("RuleConfigCreator")
  samplingRunsAsTrigger     SamplingRun[] @relation("SamplingRunTrigger")
  ruleConfigChangesAsChanger RuleConfigChangeLog[] @relation("RuleConfigChangeLogChanger")
  ruleRerunBatchesAsTrigger  RuleRerunBatch[]       @relation("RuleRerunBatchTrigger")
}

model Report {
  id               String    @id @default(uuid())
  reportNo         String    @unique
  type             String
  examName         String?
  patientName      String?
  patientId        String?
  clinicId         String
  submitterId      String
  description      String    @default("")
  diagnosis        String    @default("")
  conclusions      String    @default("")
  recommendations  String    @default("")
  toothPositions   String    @default("")
  rawContent       String    @default("")
  status           String    @default("DRAFT")
  version          Int       @default(1)
  parentReportId   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  clinic           Clinic    @relation(fields: [clinicId], references: [id])
  submitter        User      @relation("SubmittedReports", fields: [submitterId], references: [id])
  parentReport     Report?   @relation("ReportVersions", fields: [parentReportId], references: [id])
  childReports     Report[]  @relation("ReportVersions")
  ruleChecks       RuleCheckResult[]
  auditTasks       AuditTask[]
  auditFeedbacks   AuditFeedback[]
}

model RuleCheckResult {
  id          String   @id @default(uuid())
  reportId    String
  ruleCode    String
  ruleName    String
  severity    String
  passed      Boolean
  message     String
  fieldName   String?
  suggestion  String?
  ruleSnapshot String?
  batchId     String?
  createdAt   DateTime @default(now())

  report      Report        @relation(fields: [reportId], references: [id])
  batch       RuleRerunBatch? @relation(fields: [batchId], references: [id])

  @@index([batchId])
}

model SamplingRule {
  id          String   @id @default(uuid())
  name        String
  clinicId    String?
  auditorId   String?
  reportType  String?
  submitterId String?
  samplingRate Float   @default(0.2)
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic      Clinic?  @relation(fields: [clinicId], references: [id])
  auditor     User?    @relation("SamplingRuleAuditor", fields: [auditorId], references: [id])
  submitter   User?    @relation("SamplingRuleSubmitter", fields: [submitterId], references: [id])
  createdBy   User     @relation("SamplingRuleCreator", fields: [createdById], references: [id])
}

model AuditTask {
  id             String    @id @default(uuid())
  reportId       String
  taskDate       DateTime
  status         String    @default("PENDING")
  assignedToId   String?
  assignedById   String?
  assignedAt     DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  rectifiedAt    DateTime?
  lastRemindedAt DateTime?
  priority       Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())

  report         Report    @relation(fields: [reportId], references: [id])
  assignedTo     User?     @relation("AssignedTasks", fields: [assignedToId], references: [id])
  assignedBy     User?     @relation("ManagedAudits", fields: [assignedById], references: [id])
  feedbacks      AuditFeedback[]
}

model AuditFeedback {
  id             String   @id @default(uuid())
  taskId         String
  reportId       String
  auditorId      String
  issueCategory  String
  issueLabel     String
  fieldName      String?
  oldValue       String?
  newValue       String?
  modification   String   @default("")
  note           String   @default("")
  isResolved     Boolean  @default(false)
  resolvedBy     String?
  resolvedAction String?
  resolvedNote   String?
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  task           AuditTask @relation(fields: [taskId], references: [id])
  report         Report    @relation(fields: [reportId], references: [id])
  auditor        User      @relation("AuditFeedbackAuditor", fields: [auditorId], references: [id])
}

model RuleConfig {
  id          String   @id @default(uuid())
  ruleCode    String
  ruleName    String
  reportType  String?
  enabled     Boolean  @default(true)
  severity    String   @default("WARNING")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User     @relation("RuleConfigCreator", fields: [createdById], references: [id])
  changeLogs  RuleConfigChangeLog[]

  @@unique([ruleCode, reportType], name: "RuleConfigRuleCodeReportTypeKey")
}

model RuleConfigChangeLog {
  id              String   @id @default(uuid())
  ruleConfigId    String
  ruleCode        String
  reportType      String?
  fieldName       String
  oldValue        String?
  newValue        String?
  changedById     String
  createdAt       DateTime @default(now())

  ruleConfig      RuleConfig @relation(fields: [ruleConfigId], references: [id])
  changedBy       User       @relation("RuleConfigChangeLogChanger", fields: [changedById], references: [id])

  @@index([ruleConfigId])
  @@index([ruleCode, reportType])
  @@index([changedById])
}

model SamplingRun {
  id            String   @id @default(uuid())
  taskDate      DateTime
  status        String   @default("COMPLETED")
  totalReports  Int      @default(0)
  createdTasks  Int      @default(0)
  skippedTasks  Int      @default(0)
  triggeredById String
  triggerType   String   @default("SCHEDULED")
  note          String?
  createdAt     DateTime @default(now())

  triggeredBy   User     @relation("SamplingRunTrigger", fields: [triggeredById], references: [id])
  items         SamplingRunItem[]
}

model SamplingRunItem {
  id              String    @id @default(uuid())
  runId           String
  reportId        String
  reportNo        String
  clinicId        String
  submitterId     String
  reportType      String
  matchedRuleId   String?
  matchedRuleName String?
  samplingRate    Float     @default(0)
  selected        Boolean   @default(false)
  existingTask    Boolean   @default(false)
  assignedToId    String?
  priority        Int       @default(0)
  createdAt       DateTime  @default(now())

  run             SamplingRun @relation(fields: [runId], references: [id])

  @@index([runId, selected], name: "SamplingRunItemRunIdSelectedIdx")
}

model RuleRerunBatch {
  id              String   @id @default(uuid())
  batchNo         String   @unique
  triggeredById   String
  triggerType     String   @default("MANUAL")   // MANUAL | SCHEDULED | POST_CONFIG_CHANGE
  ruleSnapshot    String?                      // 运行时的规则配置 JSON
  reportIds       String?                      // 影响的报告 ID 列表 JSON
  details         String?                      // 每份报告的差异明细 JSON [{reportId, reportNo, newIssues, removedIssues, oldStatus, newStatus}]
  affectedCount   Int      @default(0)         // 实际影响报告数
  newIssueCount   Int      @default(0)         // 新增问题数（相比上次检查）
  removedCount    Int      @default(0)         // 消失问题数
  changedCount    Int      @default(0)         // 有变化的报告数
  note            String?
  createdAt       DateTime @default(now())

  triggeredBy     User              @relation("RuleRerunBatchTrigger", fields: [triggeredById], references: [id])
  ruleChecks      RuleCheckResult[]

  @@index([triggeredById])
  @@index([createdAt])
}
